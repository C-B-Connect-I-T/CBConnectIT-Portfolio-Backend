{
  "info": {
    "name": "CBConnectIT Portfolio API",
    "_postman_id": "cbconnectit-portfolio-api",
    "description": "API collection for CBConnectIT Portfolio Backend.\n\nSet the `baseUrl` variable to your server (e.g. `http://localhost:8080`) and populate `accessToken` after logging in.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT bearer token — paste after /auth/login"
    },
    {
      "key": "serviceId",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('accessToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Get all services",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] }
          }
        },
        {
          "name": "Get service by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        },
        {
          "name": "Create service (multipart — mandatory image + bannerImage)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "payload",
                  "value": "{\n  \"title\": \"Mobile development\",\n  \"description\": \"Native Android development expertise.\",\n  \"short_description\": \"Android apps, built right.\",\n  \"image_alt_text\": \"Mobile service icon\",\n  \"banner_image_alt_text\": \"Mobile development banner\",\n  \"banner_description\": \"Deep dive into the mobile world.\",\n  \"extra_info\": null,\n  \"parent_service_id\": null,\n  \"tag_id\": null\n}",
                  "type": "text",
                  "description": "JSON payload (serialized InsertNewService)"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "IMAGE type — square icon/thumbnail (required)"
                },
                {
                  "key": "bannerImage",
                  "type": "file",
                  "src": [],
                  "description": "BANNER type — wide hero image (required)"
                }
              ]
            },
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] }
          }
        },
        {
          "name": "Update service — replace both images (multipart)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "payload",
                  "value": "{\n  \"title\": \"Mobile development (updated)\",\n  \"description\": \"Updated description.\",\n  \"short_description\": \"Short updated.\",\n  \"image_alt_text\": \"New icon alt text\",\n  \"banner_image_alt_text\": \"New banner alt text\"\n}",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "New IMAGE file — replaces existing (optional)"
                },
                {
                  "key": "bannerImage",
                  "type": "file",
                  "src": [],
                  "description": "New BANNER file — replaces existing (optional)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        },
        {
          "name": "Update service — metadata only, no new images (JSON)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mobile development (metadata only)\",\n  \"description\": \"Only text fields updated — images unchanged.\",\n  \"short_description\": \"Still the same icon, new words.\",\n  \"image_alt_text\": \"Updated alt text without re-uploading\",\n  \"banner_image_alt_text\": \"Updated banner alt without re-uploading\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        },
        {
          "name": "Delete service",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Get all projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Get project by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Create project (multipart — mandatory image + bannerImage)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "payload",
                  "value": "{\n  \"title\": \"Android Core\",\n  \"short_description\": \"A core library to streamline new project setup.\",\n  \"description\": \"Full project description here.\",\n  \"image_alt_text\": \"Android Core project thumbnail\",\n  \"banner_image_alt_text\": \"Android Core banner\",\n  \"tags\": [],\n  \"links\": []\n}",
                  "type": "text",
                  "description": "JSON payload (serialized InsertNewProject)"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "IMAGE type — project thumbnail (required)"
                },
                {
                  "key": "bannerImage",
                  "type": "file",
                  "src": [],
                  "description": "BANNER type — wide hero image (required)"
                }
              ]
            },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Update project — replace both images (multipart)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "payload",
                  "value": "{\n  \"title\": \"Android Core (updated)\",\n  \"short_description\": \"Updated short description.\",\n  \"description\": \"Updated full description.\",\n  \"image_alt_text\": \"New thumbnail alt\",\n  \"banner_image_alt_text\": \"New banner alt\",\n  \"tags\": [],\n  \"links\": []\n}",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "New IMAGE file — replaces existing (optional)"
                },
                {
                  "key": "bannerImage",
                  "type": "file",
                  "src": [],
                  "description": "New BANNER file — replaces existing (optional)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Update project — metadata only, no new images (JSON)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Android Core (text only update)\",\n  \"short_description\": \"Images untouched, only text changed.\",\n  \"description\": \"No files uploaded — existing image and bannerImage are kept.\",\n  \"image_alt_text\": \"Updated alt without re-upload\",\n  \"banner_image_alt_text\": \"Updated banner alt without re-upload\",\n  \"tags\": [],\n  \"links\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Client-Type", "value": "web" }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        }
      ]
    }
  ]
}
